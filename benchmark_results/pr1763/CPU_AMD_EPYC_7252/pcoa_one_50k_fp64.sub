#!/bin/bash
source ~/.bashrc
hostname
lscpu
date

export OMP_NUM_THREADS=8

conda activate skbio-local

for i in 50 ; do 
taskset -c 0-7 time python ../../scripts/pcoa_load_only.py "${i}000 fp64" ../../inputs/unifrac_${i}000_pcoa_10.fp64.h5 
taskset -c 0-7 time python ../../scripts/pcoa_one.py "${i}000 fp64" ../../inputs/unifrac_${i}000_pcoa_10.fp64.h5
taskset -c 0-7 time python ../../scripts/pcoa_inline.py "${i}000 fp64" ../../inputs/unifrac_${i}000_pcoa_10.fp64.h5
done
